{
  "name": "agy-extension",
  "displayName": "AGY CLI",
  "description": "Quickly open AGY CLI in a native terminal.",
  "version": "0.0.5",
  "publisher": "Hsiang0717",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hsiang0717/skill-development"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:agy.start",
    "onCommand:agy.wrapAsConflict",
    "onCommand:agy.copyAsIntentDiff"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agy.start",
        "title": "Open AGY CLI",
        "icon": "resources/icon.svg"
      },
      {
        "command": "agy.wrapAsConflict",
        "title": "AGY: Wrap as Intent Conflict"
      },
      {
        "command": "agy.copyAsIntentDiff",
        "title": "AGY: Copy as Intent Prompt",
        "icon": "$(copy)"
      }
    ],
    "keybindings": [
      {
        "command": "agy.wrapAsConflict",
        "key": "alt+-",
        "when": "editorTextFocus"
      },
      {
        "command": "agy.copyAsIntentDiff",
        "key": "alt+shift+c",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "agy.start",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "agy.copyAsIntentDiff",
          "group": "navigation",
          "when": "true"
        }
      ],
      "editor/context": [
        {
          "command": "agy.wrapAsConflict",
          "group": "agy@1",
          "when": "editorTextFocus"
        },
        {
          "command": "agy.copyAsIntentDiff",
          "group": "agy@2",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "AGY Intent Diff",
      "properties": {
        "agy.intentDiff.prefixTemplate": {
          "type": "string",
          "default": "Please update or review the code inside the \"<<<<<<< Original\" block according to the instructions, comments, or refactoring intent provided in the \">>>>>>> Instruction / Comment\" section.",
          "markdownDescription": "System instruction prefix prepended before the file content when using **Copy as Intent Prompt**."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "install-extension": "code --install-extension *.vsix --force"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^4.7.4"
  }
}