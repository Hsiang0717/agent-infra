{
  "name": "agy-extension",
  "displayName": "AGY CLI",
  "description": "Quickly open AGY CLI in a native terminal.",
  "version": "0.0.2",
  "publisher": "Hsiang0717",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hsiang0717/skill-development"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:agy.start"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agy.start",
        "title": "Open AGY CLI",
        "icon": "resources/icon.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "agy.start",
          "group": "navigation",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "install-extension": "code --install-extension *.vsix --force"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^4.7.4"
  }
}