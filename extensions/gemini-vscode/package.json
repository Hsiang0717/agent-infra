{
  "name": "geminicli-extension",
  "displayName": "Gemini CLI",
  "description": "Quickly open Gemini CLI in a native terminal.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "geminicli.start",
        "title": "Open Gemini CLI",
        "icon": "resources/icon.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "geminicli.start",
          "group": "navigation",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^4.7.4"
  }
}